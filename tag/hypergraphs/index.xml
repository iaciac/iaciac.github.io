  &lt;a data-fancybox=&#34;&#34; href=&#34;https://iaciac.github.io/post/vanishing/Fig5_hub2373f1fbedd66063ea361b6299c19a4_3467022_2000x2000_fit_q90_lanczos.jpg&#34; data-caption=&#34;Ph by  Belinda Fewings&#34;&gt;


  &lt;img data-src=&#34;https://iaciac.github.io/post/vanishing/Fig5_hub2373f1fbedd66063ea361b6299c19a4_3467022_2000x2000_fit_q90_lanczos.jpg&#34; class=&#34;lazyload&#34; alt=&#34;&#34; width=&#34;700&#34; height=&#34;3456&#34;&gt;
&lt;/a&gt;


  
  
